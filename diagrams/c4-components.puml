@startuml C4-Components
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title C4 Components — Архитектурный квант поддержки проектов

System_Boundary(platform, "Краудфандинговая платформа") {
  Container_Boundary(quantum, "Crowdfunding Quantum") {

    Component(user_svc, "User Service", "Go", "Пользователи и аутентификация")
    Component(project_svc, "Project Service", "Go", "Проекты и модерация")
    Component(payment_svc, "Payment Service", "Go", "Взносы и платежи")
    Component(promo_svc, "Promo Service", "Go", "Промокоды")

    ComponentQueue(kafka, "Message Broker", "Kafka", "Kafka cluster")

    ComponentDb(users_db, "users_db", "PostgreSQL", "Пользователи")
    ComponentDb(projects_db, "projects_db", "PostgreSQL", "Проекты и заявки")
    ComponentDb(payments_db, "payments_db", "PostgreSQL", "Платежи")
    ComponentDb(promocodes_db, "promocodes_db", "PostgreSQL", "Промокоды")
    ComponentDb(redis, "Redis", "Redis", "Refresh-токены")
    ComponentDb(minio, "Object Storage", "MinIO", "Хранилище изображений")
  }
}

Rel(payment_svc, project_svc, "Проверяет статус проекта", "REST")
Rel(project_svc, promo_svc, "Использует промокод", "REST")

Rel(user_svc, kafka, "Публикует события регистрации", "user topic")
Rel(project_svc, kafka, "Публикует события проектов", "project topic")
Rel(kafka, project_svc, "Передаёт события о взносах", "contribution topic")
Rel(payment_svc, kafka, "Публикует события о взносах", "contribution topic")
Rel(kafka, payment_svc, "Передаёт события о проектах", "project topic")
Rel(kafka, promo_svc, "Передаёт события регистрации", "user topic")

Rel(user_svc, users_db, "Читает и записывает")
Rel(user_svc, redis, "Хранит refresh-токены")
Rel(project_svc, projects_db, "Читает и записывает")
Rel(payment_svc, payments_db, "Читает и записывает")
Rel(promo_svc, promocodes_db, "Читает и записывает")

Rel(user_svc, minio, "Загружает аватарки", "S3 API")

@enduml
