@startuml C4-Containers
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title C4 Containers — Краудфандинговая платформа

Person(guest, "Гость", "Просматривает проекты\nи профили пользователей")
Person(user, "Пользователь", "Создаёт проекты, делает взносы,\nуправляет профилем")
Person(moderator, "Модератор", "Рассматривает заявки на публикацию\nпроектов, одобряет или отклоняет их")

System_Boundary(platform, "Краудфандинговая платформа") {

    Container(frontend, "Web App", "SvelteKit / TypeScript", "Пользовательский интерфейс платформы")

    Container(traefik, "Ingress Controller", "Traefik", "Единая точка входа")

    Container(quantum, "Crowdfunding Quantum", "Go", "Архитектурный квант поддержки проектов")
}

Rel(guest, frontend, "Просматривает проекты и профили пользователей")
Rel(user, frontend, "Авторизуется, создаёт проекты,\nделает взносы, использует промокоды")
Rel(moderator, frontend, "Одобряет и отклоняет\nзаявки на публикацию проектов")

Rel(frontend, traefik, "API-запросы")
Rel(traefik, quantum, "Маршрутизация запросов")

@enduml
