@startuml C4-Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title C4 Context — Краудфандинговая платформа

Person(guest, "Гость", "Незарегистрированный пользователь.\nПросматривает проекты и профили.")

Person(user, "Пользователь", "Зарегистрированный пользователь.\nСоздаёт проекты, делает взносы,\nуправляет профилем.")

Person(moderator, "Модератор", "Рассматривает заявки на публикацию\nпроектов, одобряет или отклоняет их.")

System(platform, "Краудфандинговая платформа", "Позволяет пользователям создавать\nкраудфандинговые проекты, собирать\nфинансирование и взаимодействовать\nдруг с другом.")

Rel(guest, platform, "Просматривает проекты и профили пользователей")
Rel(user, platform, "Авторизуется, создаёт проекты,\nделает взносы, использует промокоды")
Rel(moderator, platform, "Одобряет и отклоняет\nзаявки на публикацию проектов")

@enduml
